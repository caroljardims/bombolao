VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Opcional — placares ao vivo no app (pode falhar por CORS; TheSportsDB é fallback automático)
VITE_FOOTBALL_DATA_TOKEN=
VITE_FOOTBALL_DATA_COMPETITION=WC

# For scripts/sync-scores.ts (terminal local)
FOOTBALL_DATA_TOKEN=
# Salve como service-account.json na raiz do projeto (já está no .gitignore)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
